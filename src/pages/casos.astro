---
import Layout from '../layouts/Layout.astro';
import CaseStudyModal from '../components/CaseStudyModal.astro';

const caseStudies = [
  {
    image: '/DestinationDecoderExp.svg',
    imageBg: 'bg-slate-100',
    date: '2024-2025',
    tags: 'Travel & AI',
    title: 'Scaling Growth through Motion & Systems',
    onClick: "document.getElementById('modal-expedia').showModal()",
    description: 'Leading cross-platform experiences for web and mobile. Contributed to $14.9M GP and 1.48M installs by surpassing annual targets by 148%.',
    logo: '/expedia-logo.png',
    company: 'Expedia Group',
    role: 'Product Designer'
  },
  {
    image: 'https://images.unsplash.com/photo-1507238691740-187a5b1d37b8?q=80&w=800&auto=format&fit=crop',
    imageBg: 'bg-slate-100',
    date: '2025-Present',
    tags: 'Design Systems, VD & Design Ops',
    title: 'Elevating Design Excellence & Ops at Scale',
    onClick: "document.getElementById('modal-airgas').showModal()",
    description: 'Redesigned, managed and evolved complex UI libraries for a Fortune 500 client, ensuring 100% design-to-dev alignment.',
    logo: '/Air-Liquide-logo.png',
    company: 'Air Liquide',
    role: 'Design Lead'
  },
  {
    image: '/Coign.png',
    imageBg: 'bg-slate-900',
    imageExtra: 'object-left-top',
    date: '2025',
    tags: 'UX & Design Ops',
    title: 'Optimizing the Bench LATAM Design Operations Lifecycle',
    onClick: "document.getElementById('modal-epam').showModal()",
    description: 'I led a strategic discovery initiative to map the end-to-end Epamer Journey, identifying structural bottlenecks and cross-functional dependencies to streamline operations for the LATAM region.',
    logo: '/EPAM-logo.png',
    company: 'EPAM',
    role: 'Lead UX Designer'
  },
  {
    image: '/Coign.png',
    imageBg: 'bg-slate-100',
    date: '2023',
    tags: 'Fintech & Visual Design',
    title: 'Architecting an "Unmissable" Experience',
    onClick: "document.getElementById('modal-coign').showModal()",
    description: 'Spearheaded a robust Web App that unified applicant management, earning praise from The Wall Street Journal.',
    logo: '/coign-logo.png',
    company: 'Coign',
    role: 'Product Designer'
  },
  {
    image: '/DestinationDecoderExp.svg',
    imageBg: 'bg-slate-100',
    date: '2022',
    tags: 'Production & Data Architecture',
    title: 'Revolutionizing Production Planning at Scale',
    onClick: "document.getElementById('modal-ekos').showModal()",
    description: 'Reduced development time by 20% and increased customer satisfaction by 15% by...',
    logo: '/Ekos-logo.webp',
    company: 'Ekos',
    role: 'Product Designer'
  },
  {
    image: '/DestinationDecoderExp.svg',
    imageBg: 'bg-slate-100',
    date: '2021',
    tags: 'Payments & Visual Design',
    title: 'UI Library for B2B payments webapp',
    onClick: "document.getElementById('modal-boost').showModal()",
    description: 'Conducting an extensive audit and establishing a UI Library proved instrumental for our design team, fostering the ability to suggest and craft consistently cohesive interfaces. This initiative significantly diminished the time and effort invested in each project. The positive impact extended to our development team, who noted appreciable time savings through the reuse of components and streamlining the creation of interfaces we were designing.',
    logo: '/boost-logo.png',
    company: 'Boost',
    role: 'Visual Designer'
  }
];
---

<Layout>

  <CaseStudyModal 
    id="modal-airgas"
    category="Design Systems, VD & Design Ops"
    title="Elevating Design Excellence & Ops at Scale'"
    images={[
      '/airgas-1.png',
      '/airgas-2.png',
      '/airgas-3.png'
    ]}
    relatedCases={[
      { id: 'modal-epam', title: 'Optimizing the Bench LATAM Design Operations Lifecycle', category: 'UX & Design Ops' },
      { id: 'modal-expedia', title: 'Scaling Growth through Motion & Systems', category: 'Travel & AI' }
    ]}
  />

  <CaseStudyModal 
    id="modal-epam"
    category="UX & Design Ops"
    title="Optimizing the Bench LATAM Design Operations Lifecycle"
    images={[
      '/epam-1.png',
      '/epam-2.png'
    ]}
    relatedCases={[
      { id: 'modal-expedia', title: 'Scaling Growth through Motion & Systems', category: 'Travel & AI' },
      { id: 'modal-airgas', title: 'Elevating Design Excellence & Ops at Scale', category: 'Design Systems, VD & Design Ops' }
    ]}
  />

  <CaseStudyModal 
    id="modal-expedia"
    category="Travel & AI"
    title="Scaling Growth through Motion & Systems"
    images={[
      '/expedia-1.png',
      '/expedia-2.png',
      '/expedia-3.png',
      '/expedia-4.png',
      '/expedia-5.png',
      '/expedia-6.png',
      '/expedia-7.png',
      '/expedia-8.png',
      '/expedia-9.png',
      '/expedia-10.png',
      '/expedia-11.png',
      '/expedia-12.png'
    ]}
    relatedCases={[
      { id: 'modal-coign', title: 'Architecting an Unmissable Experience', category: 'Fintech & Visual Design' },
      { id: 'modal-epam', title: 'Optimizing the Bench LATAM Design Operations Lifecycle', category: 'UX & Design Ops' }
    ]}
  />

  <CaseStudyModal 
    id="modal-coign"
    category="Fintech & Visual Design"
    title="Architecting an Unmissable Experience"
    images={[
      '/coign-1.png',
      '/coign-2.png',
      '/coign-3.png',
      '/coign-4.png',
      '/coign-5.png',
      '/coign-6.png',
      '/coign-7.png',
      '/coign-8.png'
    ]}
    relatedCases={[
      { id: 'modal-ekos', title: 'Revolutionizing Production Planning at Scale', category: 'Production & Data Architecture' },
      { id: 'modal-expedia', title: 'Scaling Growth through Motion & Systems', category: 'Travel & AI' }
    ]}
  />


  <CaseStudyModal 
    id="modal-ekos"
    category="Production & Data Architecture"
    title="Revolutionizing Production Planning at Scale"
    images={[
      '/ekos-1.png',
      '/ekos-2.png',
      '/ekos-3.png',
      '/ekos-4.png',
      '/ekos-5.png',
      '/ekos-6.png',
      '/ekos-7.png',
      '/ekos-8.png',
      '/ekos-9.png'
    ]}
    relatedCases={[
      { id: 'modal-boost', title: 'UI Library for B2B payments webapp', category: 'Payments & Visual Design' },
      { id: 'modal-coign', title: 'Architecting an Unmissable Experience', category: 'Fintech & Visual Design' }
    ]}
  />

  <CaseStudyModal 
    id="modal-boost"
    category="Payments & Visual Design"
    title="UI Library for B2B payments webapp"
    images={[
      '/boost-1.png',
      '/boost-2.png',
      '/boost-3.png'
    ]}
    relatedCases={[
      { id: 'modal-airgas', title: 'Elevating Design Excellence & Ops at Scale', category: 'Design Systems, VD & Design Ops' },
      { id: 'modal-ekos', title: 'Revolutionizing Production Planning at Scale', category: 'Production & Data Architecture' }
    ]}
  />

    <div class="bg-slate-50 py-24 sm:py-32">
        <div class="mx-auto max-w-7xl px-6 lg:px-8">
            <div class="mx-auto max-w-2xl text-center">
                <h2
					class="mx-auto mt-2 text-center text-5xl tracking-tight text-balance text-gray-950 sm:text-6xl">
					Turning Complex Challenges into Seamless Experiences</h2>
            </div>

            <div class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-20 lg:mx-0 lg:max-w-none lg:grid-cols-3">

                {caseStudies.map((study) => (
                    <article class="relative flex flex-col items-start justify-between group cursor-pointer">
                        <div class="relative w-full overflow-hidden rounded-2xl">
                            <img src={study.image} alt=""
                                class={`aspect-[16/9] w-full ${study.imageBg} object-cover ${study.imageExtra || ''} sm:aspect-[2/1] lg:aspect-[3/2] transition-transform duration-500 group-hover:scale-105`} />
                            <div class="absolute inset-0 rounded-2xl ring-1 ring-inset ring-slate-900/10 pointer-events-none"></div>
                        </div>
                        <div class="max-w-xl w-full">
                            <div class="mt-6 flex items-center gap-x-4 text-xs">
                                <span class="text-slate-500">{study.date}</span>
                                <span class="relative z-10 rounded-full bg-white px-3 py-1.5 font-medium text-slate-600 ring-1 ring-slate-200">
                                    {study.tags}
                                </span>
                            </div>
                            <div class="group">
                                <h3 class="mt-3 text-xl font-bold text-slate-900 group-hover:text-brand transition-colors">
                                    {study.onClick ? (
                                        <a onclick={study.onClick} class="btn-primary">
                                            <span class="absolute inset-0 z-10"></span>
                                            {study.title}
                                        </a>
                                    ) : (
                                        <a href={study.linkUrl}>
                                            <span class="absolute inset-0 z-10"></span>
                                            {study.title}
                                        </a>
                                    )}
                                </h3>
                                <p class="mt-4 line-clamp-3 text-sm/6 text-slate-600">{study.description}</p>
                            </div>
                            <div class="relative mt-8 flex items-center gap-x-4 border-t border-slate-100 pt-6">
                                <img src={study.logo} alt="" class="size-10 rounded-full bg-slate-50 object-cover ring-1 ring-slate-200" />
                                <div class="text-sm/6">
                                    <p class="font-bold text-slate-900">{study.company}</p>
                                    <p class="text-slate-600">{study.role}</p>
                                </div>
                            </div>
                        </div>
                    </article>
                ))}

            </div>
        </div>
    </div>

    <script is:inline>
        document.addEventListener('DOMContentLoaded', () => {
            const params = new URLSearchParams(window.location.search);
            const caseId = params.get('case');
            if (caseId) {
                const modal = document.getElementById(`modal-${caseId}`);
                if (modal) {
                    modal.showModal();
                }
            }
        });
    </script>
</Layout>