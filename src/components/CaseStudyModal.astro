---
interface Props {
  id: string;
  title: string;
  category: string;
  images: string[]; // Lista de rutas a tus PNG/SVG
  relatedCases?: { id: string; title: string; category?: string }[];
}

const { id, title, category, images, relatedCases = [] } = Astro.props;
---

<dialog id={id} class="backdrop:bg-slate-900/80 backdrop:backdrop-blur-sm bg-transparent p-0 m-0 max-w-none max-h-none w-full h-full fixed inset-0 z-[100] outline-none group">
  
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[95vw] sm:w-[90vw] h-[95vh] sm:h-[90vh] rounded-2xl shadow-2xl flex flex-col items-center overflow-y-auto bg-slate-50 py-12 px-4">
    
    <button onclick={`document.getElementById('${id}').close()`} class="fixed top-4 right-4 md:top-8 md:right-8 z-[110] bg-white/80 backdrop-blur-md border border-slate-200 p-3 md:p-4 rounded-full hover:bg-brand hover:text-white transition-all shadow-xl hover:scale-110">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-5 md:size-6">
        <path d="M6 18L18 6M6 6l12 12" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <div class="flex flex-col w-[100%]">
      {images.map((img) => (
        <div class=" overflow-hidden bg-white">
          <img src={img} alt="Project Frame" class="w-full h-auto loading-lazy" />
        </div>
      ))}
    </div>

    <footer class="mt-20 pb-12 w-full max-w-5xl flex flex-col items-center">
      {relatedCases.length > 0 && (
        <div class="w-full border-t border-slate-200 pt-12 mb-12">
          <h3 class="text-sm font-semibold text-slate-500 uppercase tracking-widest text-center mb-8">Otros casos de estudio</h3>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 w-full px-4">
            {relatedCases.map((related) => (
              <button 
                onclick={`document.getElementById('${id}').close(); document.getElementById('${related.id}').showModal();`}
                class="flex flex-col items-start p-6 bg-white rounded-2xl border border-slate-100 shadow-sm hover:shadow-md hover:border-brand/30 transition-all text-left group/card"
              >
                {related.category && <span class="text-xs font-medium text-slate-500 mb-2">{related.category}</span>}
                <span class="text-lg font-bold text-slate-900 group-hover/card:text-brand transition-colors">{related.title}</span>
                <span class="text-sm font-medium text-brand mt-4 opacity-0 -translate-x-2 group-hover/card:opacity-100 group-hover/card:translate-x-0 transition-all">Ver caso &rarr;</span>
              </button>
            ))}
          </div>
        </div>
      )}
    </footer>
  </div>
</dialog>

<style>
  /* Animación de entrada */
  dialog[open] {
    animation: fadeIn 0.3s ease-out;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* Ocultar scrollbar pero mantener funcionalidad */
  dialog div::-webkit-scrollbar {
    display: none;
  }
</style>