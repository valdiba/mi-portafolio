---
const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '/index.html';
const isCasos = pathname.startsWith('/casos');
const isSobreMi = pathname.startsWith('/sobre-mi');
---

<header id="main-header" class="group fixed top-0 z-50 w-full bg-transparent transition-all duration-300">
  <nav aria-label="Global" class="mx-auto max-w-7xl flex items-center justify-between px-6 py-4 lg:px-8">
    
    <div class="flex lg:flex-1">
      <a href="/" class="-m-1.5 p-1.5">
        <span class="sr-only">Valentina Díaz</span>
        <span class="text-2xl font-heading tracking-[-0.07em] text-black transition-colors">Valdiba.</span>
      </a>
    </div>

    <div class="flex lg:hidden">
      <button type="button" command="show-modal" commandfor="mobile-menu" class="-m-2.5 inline-flex items-center justify-center rounded-md p-2.5 text-black hover:bg-gray-50 group-[.bg-brand]:hover:bg-white/30 transition-colors">
        <span class="sr-only">Abrir menú principal</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="size-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>

    <div class="hidden lg:flex lg:gap-x-12">
      <a href="/" class={`text-sm/6 font-semibold hover:opacity-70 transition-all ${isHome ? 'text-black underline decoration-brand group-[.bg-brand]:decoration-black decoration-2 underline-offset-4' : 'text-slate-500'}`}>Home</a>
      <a href="/casos" class={`text-sm/6 font-semibold hover:opacity-70 transition-all ${isCasos ? 'text-black underline decoration-brand group-[.bg-brand]:decoration-black decoration-2 underline-offset-4' : 'text-slate-500'}`}>Case Studies</a>
      <a href="/sobre-mi" class={`text-sm/6 font-semibold hover:opacity-70 transition-all ${isSobreMi ? 'text-black underline decoration-brand group-[.bg-brand]:decoration-black decoration-2 underline-offset-4' : 'text-slate-500'}`}>About Me</a>
    </div>
  </nav>

  <el-dialog>
    <dialog id="mobile-menu" class="backdrop:bg-slate-900/20 lg:hidden">
      <div tabindex="0" class="fixed inset-0 focus:outline-none">
        <el-dialog-panel class="fixed inset-y-0 right-0 z-50 w-full overflow-y-auto bg-white p-6 sm:max-w-sm shadow-2xl">
          
          <div class="flex items-center justify-between">
            <a href="/" class="-m-1.5 p-1.5">
              <span class="sr-only">Valentina Díaz</span>
              <span class="text-2xl font-heading tracking-[-0.07em] text-slate-900">VD.</span>
            </a>
            <button type="button" command="close" commandfor="mobile-menu" class="-m-2.5 rounded-md p-2.5 text-gray-700 hover:bg-gray-50 transition-colors">
              <span class="sr-only">Cerrar menú</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true" class="size-6">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
          
          <div class="mt-6 flow-root">
            <div class="-my-6 divide-y divide-gray-100">
              <div class="space-y-2 py-6">
                <a href="/" class={`-mx-3 block rounded-lg px-3 py-2 text-base/7 font-semibold hover:bg-gray-50 transition-all ${isHome ? 'text-slate-900 bg-gray-50 underline decoration-brand decoration-2 underline-offset-4' : 'text-slate-500'}`}>Inicio</a>
                <a href="/casos" class={`-mx-3 block rounded-lg px-3 py-2 text-base/7 font-semibold hover:bg-gray-50 transition-all ${isCasos ? 'text-slate-900 bg-gray-50 underline decoration-brand decoration-2 underline-offset-4' : 'text-slate-500'}`}>Casos de estudio</a>
                <a href="/sobre-mi" class={`-mx-3 block rounded-lg px-3 py-2 text-base/7 font-semibold hover:bg-gray-50 transition-all ${isSobreMi ? 'text-slate-900 bg-gray-50 underline decoration-brand decoration-2 underline-offset-4' : 'text-slate-500'}`}>Sobre mí</a>
              </div>
            </div>
          </div>

        </el-dialog-panel>
      </div>
    </dialog>
  </el-dialog>
</header>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const header = document.getElementById('main-header');
    
    window.addEventListener('scroll', () => {
      if (window.scrollY > 20) {
        header.classList.remove('bg-transparent');
        header.classList.add('bg-brand');
      } else {
        header.classList.add('bg-transparent');
        header.classList.remove('bg-brand');
      }
    });
  });
</script>